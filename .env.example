# Backend: "auto" (default), "openai", "codex", or "anthropic"
# Auto-detect picks the first available: OpenAI API key → Codex OAuth → Anthropic OAuth
LACUNA_BACKEND=auto

# ── OpenAI (standard API) ───────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here
LACUNA_MODEL=gpt-4.1-mini

# ── Codex OAuth (piggybacks off Codex CLI session) ──────────────
# No config needed — reads ~/.codex/auth.json automatically.
# Run 'codex' once to authenticate, then set LACUNA_BACKEND=codex
# LACUNA_CODEX_MODEL=gpt-5.1-codex-mini

# ── Anthropic (API key or Claude Code OAuth) ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# LACUNA_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Fallback ────────────────────────────────────────────────────
# Auto-switch to next backend when current one hits quota/rate limits
LACUNA_FALLBACK=true
