# Primary backend: "openai" (default) or "anthropic"
LACUNA_BACKEND=openai

# OpenAI API Key (required if backend=openai)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model (default: gpt-4.1-mini)
# Options: gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o4-mini, gpt-4o-mini
LACUNA_MODEL=gpt-4.1-mini

# Anthropic API Key (optional — falls back to Claude Code OAuth if not set)
# ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model (default: claude-sonnet-4-20250514)
# LACUNA_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Auto-fallback to Anthropic when OpenAI credits exhausted (default: true)
LACUNA_FALLBACK=true
